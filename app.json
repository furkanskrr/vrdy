{
  "expo": {
    "name": "Vardiyam?",
    "slug": "vrdy",
    "scheme": "vrdy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1419"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vrdy.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1419"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.vrdy.app",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "Vardiyam?",
      "shortName": "Vardiyam",
      "themeColor": "#0f1419",
      "backgroundColor": "#0f1419",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#3B82F6",
          "defaultChannel": "default"
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9fc1f452-c211-456e-8811-998c888d9c05"
    },
    "extra": {
      "eas": {
        "projectId": "9fc1f452-c211-456e-8811-998c888d9c05"
      }
    },
    "owner": "furkanskrr"
  }
}
